# ─── MQTT Broker ───
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_QOS=1

# ─── PostgreSQL / TimescaleDB ───
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=carbon_emissions
POSTGRES_USER=carbon_admin
POSTGRES_PASSWORD=changeme_in_production

# ─── FastAPI Backend ───
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ─── Edge Gateway ───
EDGE_SQLITE_PATH=./data/edge_buffer.db
EDGE_FORWARD_URL=http://localhost:8000/api/v1/ingest
EDGE_FORWARD_INTERVAL_SEC=5
EDGE_MAX_RETRY=5

# ─── Simulation ───
NUM_FACILITIES=50
SAMPLING_INTERVAL_SEC=15
SIMULATION_SPEED_MULTIPLIER=1
